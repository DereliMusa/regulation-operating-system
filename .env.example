# Copy to .env and fill in. .env is git-ignored.

# nuxt-auth-utils session cookie encryption key (minimum 32 characters). Required.
NUXT_SESSION_PASSWORD=replace-with-a-long-random-string-at-least-32-chars

# SQLite database file location (MVP).
DATABASE_PATH=./.data/certra.db

# Canonical site URL used for SSR and absolute links.
NUXT_PUBLIC_SITE_URL=http://localhost:3000
